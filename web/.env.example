# SECRET ROTATION: before a production deploy, rotate every secret-valued var
# below (anything that isn't a URL, DEMO_KEY, or a `NEXT_PUBLIC_*` public
# value) — do not reuse local/dev values in production. See ../README.md
# "Secret rotation" for the full checklist.

# Feature flag: enable Google as an auth provider on the sign-in screen.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
# Base URL of the shared Star Sailors PocketBase (auth + shared platform data).
SHARED_PB_URL=http://127.0.0.1:8090
NEXT_PUBLIC_SHARED_PB_URL=http://127.0.0.1:8090
# Base URL of the Saily-specific PocketBase (game data).
SAILY_PB_URL=http://127.0.0.1:8092
NEXT_PUBLIC_SAILY_PB_URL=http://127.0.0.1:8092
# Client-side PostHog project token — public, safe to expose to the browser.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# PostHog survey IDs shown after specific game types. Leave blank to disable
# the corresponding survey.
NEXT_PUBLIC_POSTHOG_SURVEY_PLANET_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_NO_PLANET_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_MARS_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_RUBIN_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_GAIA_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_NARRATIVE_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_ARCHIVE_ID=
NEXT_PUBLIC_POSTHOG_SURVEY_DISCUSS_ID=
# App build/version identifier surfaced in the UI and error reports. Bump per
# release; keep in sync across every environment file (web/.env*, .env.docker*).
NEXT_PUBLIC_APP_VERSION=v1
# NASA open API key (images-api.nasa.gov, etc). DEMO_KEY works for local dev
# but is rate-limited; request a real key for staging/production.
NASA_API_KEY=DEMO_KEY

# Landing page interest capture. Keep server-side captures on the server token.
# POSTHOG_PROJECT_TOKEN is SECRET.
POSTHOG_PROJECT_TOKEN=phc_your_project_api_key
POSTHOG_CAPTURE_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=199773
POSTHOG_PROJECT_REGION=US Cloud
# PostHog personal API key used by admin/reporting scripts. SECRET — scope to
# the minimum required permissions and rotate regularly.
POSTHOG_PERSONAL_API_KEY=

# Newsletter (Resend) - landing-page signups are mirrored into this audience.
# RESEND_API_KEY is SECRET.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Verified sender address for transactional emails (must be a domain verified in Resend)
RESEND_FROM_EMAIL=
# Recipient for landing-page vote notifications
LANDING_VOTE_NOTIFY_EMAIL=liam@skinetics.tech

# Shared PocketBase superuser, used by E2E setup scripts to create/delete
# disposable auth users. SECRET credential pair — rotate the password on every
# environment promotion.
SHARED_PB_SUPERUSER_EMAIL=
SHARED_PB_SUPERUSER_PASSWORD=

# Saily PocketBase superuser, used by /api/admin/newsletter-sync and E2E
# cleanup of game/profile records. SECRET credential pair — rotate the password
# on every environment promotion.
SAILY_PB_SUPERUSER_EMAIL=
SAILY_PB_SUPERUSER_PASSWORD=

# Shared secret required in the x-admin-secret header for
# /api/admin/newsletter-sync. SECRET — generate a fresh random value per
# environment, never reuse across dev/staging/prod.
ADMIN_SYNC_SECRET=

# Backend-only CMS editor allowlist. Configure these on the Saily PocketBase
# backend process, not in the browser bundle.
CMS_EDITOR_EMAILS=
CMS_EDITOR_USER_IDS=

# Push notifications for new article publication (STS-148). Generate a
# VAPID keypair per environment with `npx web-push generate-vapid-keys` —
# never reuse across dev/staging/prod. NEXT_PUBLIC_VAPID_PUBLIC_KEY must
# also be set wherever the web app is built (it ships to the browser).
VAPID_SUBJECT=mailto:hello@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# SECRET shared with the Saily Go backend (see saily/backend's SAILY_WEB_URL
# + PUSH_NOTIFY_SECRET env vars) so /api/push/notify-publish only accepts
# the backend's own publish webhook.
PUSH_NOTIFY_SECRET=

# --- E2E test credentials (see .env.e2e.local, gitignored) ---------------
# Cypress/E2E runs authenticate as a disposable test user. Generate a fresh
# throwaway account per environment — never point these at a real user.
# NEXT_PUBLIC_E2E_AUTH_BYPASS=true   # dev-only: skip real auth in E2E runs
# TEST_USER_ID=
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
# TEST_RUN_TAG=
# CYPRESS_E2E_TEST_EMAIL=
# CYPRESS_E2E_TEST_PASSWORD=
# CYPRESS_E2E_TEST_RUN_TAG=
