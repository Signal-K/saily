{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "cypress:open": "env -u ELECTRON_RUN_AS_NODE cypress open",
    "cypress:run": "env -u ELECTRON_RUN_AS_NODE cypress run",
    "test:e2e": "start-server-and-test dev http://localhost:3000 cypress:run",
    "cypress:run:smoke": "env -u ELECTRON_RUN_AS_NODE cypress run --spec cypress/e2e/smoke.cy.ts",
    "cypress:run:all": "env -u ELECTRON_RUN_AS_NODE cypress run",
    "cms:validate": "node scripts/cms-validate.mjs",
    "e2e:user:create": "node scripts/e2e/create-test-user.mjs",
    "e2e:user:cleanup": "node scripts/e2e/cleanup-test-user.mjs",
    "posthog:create-landing-dashboard": "node scripts/posthog/create-landing-dashboard.mjs"
  },
  "dependencies": {
    "@dicebear/bottts": "^9.4.2",
    "@dicebear/bottts-neutral": "^9.3.1",
    "@dicebear/core": "^9.3.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@vercel/analytics": "^1.6.1",
    "next": "16.2.9",
    "posthog-js": "^1.386.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cypress": "^15.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
