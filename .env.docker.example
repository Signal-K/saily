# Copy to .env.docker and adjust if needed.
# Keep this file offline-friendly: make start reuses the existing Docker image
# and named node_modules volume. Run make bootstrap only when dependencies change.
#
# SECRET ROTATION: before a production deploy, rotate every secret-valued var
# below (anything that isn't a URL or a `NEXT_PUBLIC_*` public value) — do not
# reuse local/dev values in production. See README.md "Secret rotation" for
# the full checklist.

# Legacy Supabase-shaped vars kept for the not-yet-removed Supabase-compat
# client shim (web/src/lib/pocketbase/server.ts). Not a live Supabase project.
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_URL_INTERNAL=http://host.docker.internal:54321
# Public/publishable key — safe to expose to the browser, but still rotate it
# alongside the rest of this file when moving to a new environment.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
# Feature flag: enable Google as an auth provider on the sign-in screen.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
# Base URL of the shared Star Sailors PocketBase (auth + shared platform data).
SHARED_PB_URL=http://host.docker.internal:8090
# Encryption key for Saily PocketBase field-level encryption. SECRET — must be
# a strong, unique value in every real deployment; do not leave blank in prod.
SAILY_PB_ENCRYPTION_KEY=
# Client-side PostHog project token — public, safe to expose to the browser.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side PostHog capture token. SECRET.
POSTHOG_PROJECT_TOKEN=
POSTHOG_PROJECT_ID=199773
# PostHog personal API key used by admin/reporting scripts. SECRET — scope to
# the minimum required permissions and rotate regularly.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_CAPTURE_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.posthog.com

# App build/version identifier surfaced in the UI and error reports. Bump per
# release; keep in sync across every environment file.
NEXT_PUBLIC_APP_VERSION=v1

# Newsletter (Resend). RESEND_API_KEY is SECRET.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# PocketBase superuser (used by /api/admin/newsletter-sync to list
# landing_interest emails). SECRET credential pair — rotate the password on
# every environment promotion.
SAILY_PB_SUPERUSER_EMAIL=
SAILY_PB_SUPERUSER_PASSWORD=

# Shared secret required in the x-admin-secret header for
# /api/admin/newsletter-sync. SECRET — generate a fresh random value per
# environment, never reuse across dev/staging/prod.
ADMIN_SYNC_SECRET=

# CMS editor access. At least one of these must include the signed-in account
# before /api/saily/cms/* will list, edit, or publish articles.
CMS_EDITOR_EMAILS=
CMS_EDITOR_USER_IDS=
